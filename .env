BEHOLDEN_SUPPORT=true
BEHOLDEN_BASIC_AUTH_USER=
BEHOLDEN_BASIC_AUTH_PASS=
BEHOLDEN_RATE_LIMIT_WINDOW_MS=900000
BEHOLDEN_RATE_LIMIT_MAX=2000
WEB_PORT=5173
SERVER_PORT=5174
# On Railway, set BEHOLDEN_DATA_DIR=/data (mounted volume) via the dashboard — not here.
# Locally, leave unset to use platform default (AppData\Roaming\Beholden on Windows).
{
  "name": "@beholden/shared",
  "version": "0.0.1",
  "private": true,
  "exports": {
    "./api": "./src/api/index.ts",
    "./api/*": "./src/api/*",
    "./domain": "./src/domain/index.ts",
    "./domain/*": "./src/domain/*",
    "./icons": "./src/icons/index.tsx",
    "./icons/*": "./src/icons/*",
    "./views": "./src/views/index.tsx",
    "./views/*": "./src/views/*",
    "./ui": "./src/ui/index.tsx",
    "./ui/*": "./src/ui/*",
    "./styles/*": "./styles/*"
  },
  "typesVersions": {
    "*": {
      "domain/*": [
        "./src/domain/*"
      ],
      "ui/*": [
        "./src/ui/*"
      ],
      "api/*": [
        "./src/api/*"
      ],
      "icons/*": [
        "./src/icons/*"
      ],
      "views": [
        "./src/views/index.tsx"
      ],
      "views/*": [
        "./src/views/*"
      ]
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0"
  }
}

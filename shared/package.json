      "icons/*": ["./src/icons/*"]
    }
  },
  "devDependencies": {
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.2.3"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.8.2"
  }
}

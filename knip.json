{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "server": {
      "entry": [
        "src/main.ts",
        "src/scripts/*.ts",
        "src/**/*.test.ts"
      ],
      "project": ["src/**/*.ts"],
      "ignore": ["dist/**"]
    },
    "web-dm": {
      "entry": [
        "src/main.tsx",
        "src/**/*.test.ts"
      ],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "web-player": {
      "entry": [
        "src/main.tsx",
        "src/**/*.test.ts"
      ],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "shared": {
      "entry": [
        "src/**/index.{ts,tsx}"
      ],
      "project": ["src/**/*.{ts,tsx}"]
    }
  }
}
